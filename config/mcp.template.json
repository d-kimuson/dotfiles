{
  "mcpServers": {
    "aws-knowledge": {
      "type": "http",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "obsidian": {
      "type": "stdio",
      "command": "${OBSIDIAN_VAULT_PATH}/.obsidian/plugins/mcp-tools/bin/mcp-server",
      "args": [],
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}"
      }
    },
    "freee": {
      "command": "npx",
      "args": ["-y", "freee-mcp"]
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {
        "Authorization": "Basic ${ATLASSIAN_BASE64_ENCODED_EMAIL_AND_TOKEN}"
      }
    },
    "esa": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@esaio/esa-mcp-server"
      ],
      "env": {
        "ESA_ACCESS_TOKEN": "${ESA_ACCESS_TOKEN}",
        "LANG": "ja"
      }
    },
    "datadog": {
      "type": "stdio",
      "command": "${HOME}/.local/bin/datadog_mcp_cli",
      "args": [],
      "env": {
        "DD_API_KEY": "${DD_API_KEY}",
        "DD_APPLICATION_KEY": "${DD_APPLICATION_KEY}"
      }
    },
    "n8n": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "n8n-mcp@latest"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "${N8N_API_URL}",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    }
  }
}
