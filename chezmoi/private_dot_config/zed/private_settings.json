{
  // UI / テーマ
  "proxy": "",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "pi-acp": {
      "favorite_models": [
        "openai-codex/gpt-5.4",
        "openai-codex/gpt-5.5",
        "gateway-kimuson/gateway/balanced"
      ],
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "play_sound_when_agent_done": "always",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "edit_predictions": {
    "open_ai_compatible_api": {
      "model": "gateway/fast",
      "api_url": "https://llm-gateway.kimuson.com/api/openai/v1"
    },
    "provider": "none"
  },
  "theme": "One Dark",
  "ui_font_size": 16,
  "buffer_font_size": 17,
  "buffer_font_family": "Bizin Gothic",
  "buffer_font_features": {
    "liga": true,
    "calt": true
  },

  // エディタ基本設定
  "tab_size": 2,
  "hard_tabs": false,
  "show_whitespaces": "boundary",
  "cursor_blink": true,
  "show_wrap_guides": true,
  "wrap_guides": [80, 120],
  "relative_line_numbers": "disabled",
  "vertical_scroll_margin": 3,

  // ミニマップ（VSCode相当）
  "scrollbar": {
    "show": "auto"
  },

  // ファイルツリー
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
    "folder_actions": {
      "confirm_delete": true
    }
  },

  // Git
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },

  // 自動保存（無効）
  "autosave": "off",

  // フォーマット on save（基本オフ、言語別で設定）
  "format_on_save": "off",

  // 補完
  "show_completions_on_input": true,
  "show_completion_documentation": true,

  // ターミナル
  "terminal": {
    "font_size": 18,
    "font_family": "Hack Nerd Font Mono",
    // "option_as_meta": false,
    // "shell": {
    //   "program": "zsh"
    // },
    "working_directory": "current_project_directory",
    "env": { "LANG": "ja_JP.UTF-8", "LC_CTYPE": "ja_JP.UTF-8" }
  },

  // ファイル除外
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/node_modules",
    "**/target",
    "**/.bloop",
    "**/.metals",
    "**/.ammonite"
  ],

  // 言語別設定
  "languages": {
    "Python": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "Makefile": {
      "hard_tabs": true
    },
    "YAML": {
      "tab_size": 2
    },
    "JSON": {
      "tab_size": 2
    },
    "TypeScript": {
      "tab_size": 2,
      "language_servers": ["vtsls", "!typescript-language-server", "!tsgo", "..."]
    },
    "TSX": {
      "tab_size": 2,
      "language_servers": ["vtsls", "!typescript-language-server", "!tsgo", "..."]
    },
    "JavaScript": {
      "tab_size": 2,
      "language_servers": ["vtsls", "!typescript-language-server", "!tsgo", "..."]
    },
    "JSX": {
      "tab_size": 2,
      "language_servers": ["vtsls", "!typescript-language-server", "!tsgo", "..."]
    }
  },

  // LSP 設定
  "lsp": {
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": false,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true
        }
      }
    }
  },

  // インデントガイド
  "indent_guides": {
    "enabled": true,
    "coloring": "fixed"
  },

  // インラインヒント
  "inlay_hints": {
    "enabled": false
  },

  // Vim モード（お好みで有効化）
  "vim_mode": false,

  // AI アシスタント（無効）
  // タブ設定
  "tabs": {
    "close_position": "left"
  },

  // テレメトリ無効
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // SSH
  "ssh_connections": [
    {
      "host": "home-server",
      "username": "kaito",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/kaito"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/acp-playground"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/ai-corp"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/pi-auto/./"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/pi-ralph/./"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/remote-agent"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/s-tec"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/sandbox-app/./"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/tsumugi"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/wiki"
          ]
        }
      ],
      "port_forwards": [
        {
          "local_port": 1355,
          "remote_port": 1355
        },
        {
          "local_port": 34567,
          "remote_port": 34567
        },
        {
          "local_port": 33333,
          "remote_port": 33333
        }
      ]
    },
    {
      "host": "home-server",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/kaito/.local/share/chezmoi"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/ai-gateway/./"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/awf"
          ]
        },
        {
          "paths": [
            "/home/kaito/repos/symphony-pi/./"
          ]
        }
      ]
    }
  ]
}
