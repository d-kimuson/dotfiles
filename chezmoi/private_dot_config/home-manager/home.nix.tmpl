{ config, pkgs, pkgsStable, pkgsMaster, lib, ... }:

let
  braveSearchCliVersion = "1.5.0";
  braveSearchCliPlatform =
    if pkgs.stdenv.hostPlatform.system == "x86_64-linux" then
      {
        suffix = "linux-amd64";
        hash = "sha256-gjqG39BnNP7oQ3HpucCKidutdpH79D2tIXqcVliCf6A=";
      }
    else if pkgs.stdenv.hostPlatform.system == "aarch64-linux" then
      {
        suffix = "linux-arm64";
        hash = "sha256-iePF05GWQgV+nwNbrD1mOgra39xvqoE/XUKnrvItD9Q=";
      }
    else if pkgs.stdenv.hostPlatform.system == "aarch64-darwin" then
      {
        suffix = "darwin-arm64";
        hash = "sha256-KXg5hyCUgOOm9s8VkVCys5rFXty23bxxwabPUthg7rE=";
      }
    else
      null;

  braveSearchCli =
    if braveSearchCliPlatform == null then
      null
    else
      pkgs.stdenvNoCC.mkDerivation rec {
        pname = "brave-search-cli";
        version = braveSearchCliVersion;

        src = pkgs.fetchurl {
          url = "https://github.com/brave/brave-search-cli/releases/download/v${version}/bx-${version}-${braveSearchCliPlatform.suffix}";
          hash = braveSearchCliPlatform.hash;
        };

        dontUnpack = true;

        installPhase = ''
          install -Dm755 "$src" "$out/bin/bx"
        '';

        meta = with lib; {
          description = "CLI for the Brave Search API";
          homepage = "https://github.com/brave/brave-search-cli";
          license = licenses.mpl20;
          platforms = [
            "x86_64-linux"
            "aarch64-linux"
            "aarch64-darwin"
          ];
          sourceProvenance = [ sourceTypes.binaryNativeCode ];
        };
      };
in
{
  home.username = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";
  home.stateVersion = "25.11"; # Please read the comment before changing.

  assertions = [
    {
      assertion = braveSearchCliPlatform != null;
      message = "brave-search-cli is only available for x86_64-linux, aarch64-linux, and aarch64-darwin.";
    }
  ];

  home.packages = [
    # 開発環境で使うツール
    pkgsStable.mise
    pkgsStable.direnv
    pkgs.starship
    pkgs.colima
    pkgs.docker
    pkgs.docker-compose
    pkgs.bun
    pkgs.pnpm
    pkgs.zsh
    pkgs.deno # required by zeno.zsh
    pkgs.caddy
    pkgsStable.zed-editor
    # mise, direnv, zed-editor: stable pin で管理

    # Language Servers
    pkgs.typescript-language-server
    pkgs.typescript

    # AI
{{ if eq .chezmoi.os "linux" }}
    pkgs.bubblewrap # required by claude-code sandbox
    pkgs.socat # required by claude-code sandbox
{{ end }}
    pkgsMaster.claude-code

    # Git
    pkgs.gh
    pkgs.ghq
    pkgs.lazygit

    # 準標準
    pkgs.jq
    pkgs.lsof
    pkgs.net-tools
    pkgs.nano
    pkgs.unzip
    pkgs.wget
    pkgs.dasel

    # 標準コマンドの代替(高速・多機能)
    pkgs.fd
    pkgs.eza
    pkgs.lsd
    pkgs.ripgrep
    pkgs.bat
    pkgs.fzf
    pkgs.colordiff

{{ if eq .chezmoi.os "darwin" }}
    # 標準コマンドのGNU版統一 (macOS をLinuxに寄せる)
    pkgs.coreutils-full
    pkgs.diffutils
    pkgs.findutils
    pkgs.gnused
    pkgs.gnugrep
    pkgs.gawk
    pkgs.gnutar
{{ end }}
  ] ++ [
    braveSearchCli
  ];

  # Pueue: CLI process scheduler and manager
  # `pueue add <command>` でタスク投入、`pueue status` で確認。
  services.pueue.enable = true;

  home.activation.installZenoZsh = lib.hm.dag.entryAfter [ "writeBoundary" ] ''
    zenoDir="${config.home.homeDirectory}/.zsh/zeno"
    if [ ! -d "$zenoDir" ]; then
      $DRY_RUN_CMD ${pkgs.git}/bin/git clone https://github.com/yuki-yano/zeno.zsh.git "$zenoDir"
    fi
  '';

  home.activation.installCursorAgent = lib.hm.dag.entryAfter [ "writeBoundary" ] ''
    cursorAgentPath="${config.home.homeDirectory}/.local/bin/cursor-agent"
    homeBinDir="${config.home.homeDirectory}/bin"

    if [ ! -x "$cursorAgentPath" ]; then
      $DRY_RUN_CMD bash -c "$(${pkgs.curl}/bin/curl -fsSL https://cursor.com/install)"
    fi

    $DRY_RUN_CMD mkdir -p "$homeBinDir"
    if [ -x "$cursorAgentPath" ]; then
      $DRY_RUN_CMD ln -sf "$cursorAgentPath" "$homeBinDir/agent"
    fi
  '';

  home.activation.installMiseTools = lib.hm.dag.entryAfter [ "writeBoundary" ] ''
    miseConfigPath="${config.home.homeDirectory}/.config/mise/config.toml"
    export PATH="${pkgsStable.mise}/bin:$PATH"

    if [ -f "$miseConfigPath" ]; then
      $DRY_RUN_CMD ${pkgsStable.mise}/bin/mise install
      $DRY_RUN_CMD ${pkgsStable.mise}/bin/mise reshim
    fi
  '';

  nixpkgs.config.allowUnfree = true; # Allow unfree packages

  programs.home-manager.enable = true; # Let Home Manager install and manage itself.
}
