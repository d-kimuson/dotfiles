{ config, pkgs, pkgsMaster, beads, lib, ... }:

let
  playwrightCliPrefix = "${config.home.homeDirectory}/.npm-global";
  playwrightCliSpec = "@playwright/cli@latest";
in
{
  home.username = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";
  home.stateVersion = "25.11"; # Please read the comment before changing.

  home.packages = [
    # 開発環境で使うツール
    pkgs.mise
    pkgs.direnv
    pkgs.starship
    pkgs.colima
    pkgs.docker
    pkgs.docker-compose
    pkgs.bun
    pkgs.pnpm
    pkgs.zsh
    pkgs.deno # required by zeno.zsh
    pkgs.caddy
    # zed-editor: ビルドが重いため nix profile で分離管理 (see scripts/setup.sh)

    # Language Servers
    pkgs.typescript-language-server
    pkgs.typescript

    # AI
{{ if eq .chezmoi.os "linux" }}
    pkgs.bubblewrap # required by claude-code sandbox
    pkgs.socat # required by claude-code sandbox
{{ end }}
    pkgsMaster.claude-code
    pkgsMaster.codex
    pkgsMaster.github-copilot-cli
    pkgs.opencode
    beads

    # Git
    pkgs.gh
    pkgs.lazygit

    # 準標準
    pkgs.jq
    pkgs.lsof
    pkgs.net-tools
    pkgs.nano
    pkgs.unzip
    pkgs.wget
    pkgs.dasel

    # 標準コマンドの代替(高速・多機能)
    pkgs.fd
    pkgs.eza
    pkgs.lsd
    pkgs.ripgrep
    pkgs.bat
    pkgs.fzf
    pkgs.colordiff

{{ if eq .chezmoi.os "darwin" }}
    # 標準コマンドのGNU版統一 (macOS をLinuxに寄せる)
    pkgs.coreutils-full
    pkgs.diffutils
    pkgs.findutils
    pkgs.gnused
    pkgs.gnugrep
    pkgs.gawk
    pkgs.gnutar
{{ end }}
  ];

  home.sessionVariables = {
    NPM_CONFIG_PREFIX = playwrightCliPrefix;
  };

  home.sessionPath = [
    "${playwrightCliPrefix}/bin"
  ];

  home.activation.installZenoZsh = lib.hm.dag.entryAfter [ "writeBoundary" ] ''
    zenoDir="${config.home.homeDirectory}/.zsh/zeno"
    if [ ! -d "$zenoDir" ]; then
      $DRY_RUN_CMD ${pkgs.git}/bin/git clone https://github.com/yuki-yano/zeno.zsh.git "$zenoDir"
    fi
  '';

  home.activation.installPlaywrightCli = lib.hm.dag.entryAfter [ "writeBoundary" ] ''
    prefix=${lib.escapeShellArg playwrightCliPrefix}
    package=${lib.escapeShellArg playwrightCliSpec}

    $DRY_RUN_CMD mkdir -p "$prefix"

    if [ ! -x "$prefix/bin/playwright-cli" ]; then
      $DRY_RUN_CMD ${pkgs.nodejs}/bin/npm install --global --prefix "$prefix" "$package"
    fi
  '';

  nixpkgs.config.allowUnfree = true; # Allow unfree packages

  programs.home-manager.enable = true; # Let Home Manager install and manage itself.
}
